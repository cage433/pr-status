# As a minimum, the owner and repo-name must be specified in the config
owner:topaztechnology
repo-name:topaz

# Ignore all PRs from these authors
#ignore-author:scala-steward-topaz,github-actions

# A list of ai-authors
#ai-author:coderabbitai,claude,copilot-pull-request-reviewer

# A mapping from github handle to name
#author-name:thomasrynnetopaz=thomas,cage433=alex,jonfox=jon,davidcorcoran=dave,Lgoldfinch=louis,boomah=nick

# Ignore these PRs
# ignore-pr:1234, 4567

# Ignore comments that exactly match this
# ignore-comment:/build,@coderabbitai help,@coderabbitai full review

# aliases for reports
#alias:all-since-mk:report --filter LCT>MK

# YouTrack integration (optional)
#youtrack-url:https://yourorg.youtrack.cloud
#youtrack-token:perm-your-token-here
